#tool/write?a=0&e=/* Saves data to the dataverse. Input MUST be a JSON array: ["namespace#filename", "data to write"] */
try {
  let args = JSON.parse(INPUT);
  let path = args[0].split('#');
  let targetFile = path.length > 1 %3F path[1] : path[0];
  let targetDbName = path.length > 1 %3F path[0] : DB;
  let targetDb = await getDB(targetDbName);
  await write(args[1], targetFile, targetDb);
  return "Successfully saved to " + args[0];
} catch(e) { 
  return "Write failed: Make sure input is a valid JSON array. Error: " + e.message; 
}
