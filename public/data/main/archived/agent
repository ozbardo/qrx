<style>
  .app-container {
    display: flex;
    flex-direction: column;
    height: 100vh;
    box-sizing: border-box;
    font-family: sans-serif;
  }
  .header {
    background-color: #f1f5f9;
    padding: 20px;
    border-bottom: 1px solid #cbd5e1;
    flex-shrink: 0;
  }
  .header-title {
    margin: 0 0 15px 0;
    font-size: 24px;
    color: #1e293b;
  }
  .model-details {
    display: flex;
    gap: 20px;
    align-items: center;
  }
  .model-details label {
    display: flex;
    flex-direction: column;
    font-size: 14px;
    font-weight: bold;
    color: #475569;
    gap: 5px;
  }
  .model-details input {
    padding: 5px;
    border: 1px solid #94a3b8;
    border-radius: 4px;
  }
  .split-view {
    display: flex;
    flex-direction: row;
    flex-grow: 1;
    overflow: hidden;
  }
  .left-panel {
    width: 50%;
    overflow-y: auto;
    background-color: #f8fafc;
    border-right: 1px solid #cbd5e1;
    padding: 20px;
    box-sizing: border-box;
  }
  .right-panel {
    width: 50%;
    overflow-y: auto;
    background-color: #ffffff;
    padding: 20px;
    box-sizing: border-box;
  }
  .footer {
    display: flex;
    gap: 15px;
    background-color: #f1f5f9;
    padding: 20px;
    border-top: 1px solid #cbd5e1;
    flex-shrink: 0;
    align-items: stretch;
  }
  .footer textarea {
    flex-grow: 1;
    resize: vertical;
    min-height: 60px;
    padding: 10px;
    border: 1px solid #94a3b8;
    border-radius: 4px;
    font-family: inherit;
  }
  .button-group {
    display: flex;
    flex-direction: column;
    gap: 10px;
    justify-content: center;
  }
  .button-group button {
    padding: 10px 20px;
    cursor: pointer;
    border: none;
    border-radius: 4px;
    font-weight: bold;
  }
