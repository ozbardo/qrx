window.BaseTools = {};

window.BaseTools["read_file"] = {
  description: "Reads a file. Input MUST be namespace#filename or just filename",
  run: async function(input) {
    let d = null;
    let k = input;
    if (input.includes('#')) {
      let p = input.split('#');
      d = p[0];
      k = p[1];
    }
    return await read(k, d || db) || "File not found";
  }
};

window.BaseTools["list_files"] = {
  description: "Lists files. Input can be a namespace string, or empty for the current database.",
  run: async function(input) {
    let targetDb = input ? await getDB(input) : db;
    return JSON.stringify(await keys(undefined, targetDb));
  }
};
</script><script>
window.chatHistory = [];

async function runAgent(userMessage) {
  const rightPanel = document.querySelector('.right-panel');
  const leftPanel = document.querySelector('.left-panel');
  
  const userDiv = document.createElement('div');
  userDiv.style.padding = '10px';
  userDiv.style.borderBottom = '1px solid #ccc';
  userDiv.style.backgroundColor = '#f1f8ff';
  userDiv.innerHTML = `<strong>User:</strong> <span style="white-space: pre-wrap;">${userMessage}</span>`;
  rightPanel.appendChild(userDiv);
  
  window.chatHistory.push({ role: "User", content: userMessage });
  
  let loopCount = 0;
  let resolved = false;
  
  while (loopCount < 7) {
    loopCount++;
    
    let activeTools = Object.entries(window.BaseTools).map(x => x[0] + ' - ' + x[1].description);
    let matchedKeys = await keys(IDBKeyRange.bound('tool', 'tool\uffff'));
    
    for (const k of matchedKeys) {
      let c = await read(k);
      let desc = "";
      if (c && c.includes("/*")) {
        desc = c.split("*/")[0].split("/*")[1].trim();
      }
      activeTools.push(k + ' - ' + desc);
    }
    
    let systemPrompt = "You are an autonomous AI. Output ONLY valid JSON. If the user asks about other namespaces or databases, proactively use tools to investigate. To use a tool, output exactly: {\"thought\": \"reasoning\", \"action\": \"tool_name\", \"action_input\": \"input\"}. For the final answer, output exactly: {\"thought\": \"reasoning\", \"answer\": \"final message\"}. DO NOT wrap your response in markdown blocks.";
    systemPrompt += "\nAVAILABLE TOOLS:\n" + activeTools.join('\n');
    let fullPrompt = systemPrompt + "\n\nCHAT HISTORY:\n" + JSON.stringify(window.chatHistory);
    
    const inputs = document.querySelectorAll('.model-details input');
    const m = inputs[0].value;
    const h = inputs[1].value;
    const k_api = inputs[2].value;
    
    const u = {
      model: m,
      messages: [{ role: "user", content: fullPrompt }],
      stream: false
    };
    
    const d = { "Content-Type": "application/json" };
    if (k_api) {
      d.Authorization = `Bearer ${k_api}`;
    }
    
    let aiResponse = "";
    try {
      let a = await fetch(h, {
        method: "POST",
        headers: d,
        body: JSON.stringify(u)
      });
      let r = await a.json();
      aiResponse = r.message?.content || r.choices?.[0]?.message?.content || JSON.stringify(r);
    } catch (e) {
      aiResponse = e.message;
    }
    
    const aiDiv = document.createElement('div');
    aiDiv.style.padding = '8px';
    aiDiv.style.borderBottom = '1px solid #ddd';
    aiDiv.style.fontSize = '12px';
    aiDiv.style.fontFamily = 'monospace';
    aiDiv.style.whiteSpace = 'pre-wrap';
    aiDiv.textContent = `Iteration ${loopCount}\n${aiResponse}`;
    leftPanel.appendChild(aiDiv);
    
    let parsed;
    try {
      let startIdx = aiResponse.indexOf('{');
      let endIdx = aiResponse.lastIndexOf('}');
      if (startIdx === -1 || endIdx === -1) {
        throw new Error("Missing JSON brackets");
      }
      let jsonString = aiResponse.slice(startIdx, endIdx + 1);
      parsed = JSON.parse(jsonString);
    } catch (e) {
      window.chatHistory.push({ role: "System", content: "Error: Invalid JSON output." });
      continue;
    }
    
    if (parsed.action) {
      let toolResult = "";
      let code = "";
      try {
        if (window.BaseTools[parsed.action]) {
          toolResult = await window.BaseTools[parsed.action].run(parsed.action_input);
        } else {
          code = await read(parsed.action) || "";
          if (!code) throw new Error("Tool not found");
          toolResult = await new Function('INPUT', 'return (async () => {' + code + '})()')(parsed.action_input);
        }
        if (toolResult === undefined) {
          toolResult = "Tool executed successfully (no return value).";
        }
      } catch (err) {
        console.error("Tool Execution Failed:", err, code);
        toolResult = "Tool Execution Error: " + err.message + "\nStack: " + err.stack + "\nCode evaluated:\n" + code;
      }
      
      const obsDiv = document.createElement('div');
      obsDiv.style.padding = '8px';
      obsDiv.style.borderBottom = '1px solid #ddd';
      obsDiv.style.fontSize = '12px';
      obsDiv.style.fontFamily = 'monospace';
      obsDiv.style.backgroundColor = '#fffbe6';
      obsDiv.style.whiteSpace = 'pre-wrap';
      obsDiv.textContent = "OBSERVATION: " + toolResult;
      leftPanel.appendChild(obsDiv);
      
      window.chatHistory.push({ role: "System", content: "OBSERVATION: " + toolResult });
      continue;
    }
    
    if (parsed.answer) {
      const agentDiv = document.createElement('div');
      agentDiv.style.padding = '10px';
      agentDiv.style.borderBottom = '1px solid #ccc';
      agentDiv.style.backgroundColor = '#e6fffa';
      agentDiv.innerHTML = `<strong>Agent:</strong> <span style="white-space: pre-wrap;">${parsed.answer}</span>`;
      rightPanel.appendChild(agentDiv);
      
      window.chatHistory.push({ role: "Agent", content: parsed.answer });
      resolved = true;
      break;
    }
  }
  
  if (!resolved && loopCount >= 7) {
    const diagStr = "System Diagnostics: Agent exhausted 7 reasoning steps. Aborted. Check left-panel for looping traces.";
    const diagDiv = document.createElement('div');
    diagDiv.style.padding = '10px';
    diagDiv.style.borderBottom = '1px solid #ccc';
    diagDiv.style.backgroundColor = '#ffe6e6';
    diagDiv.style.color = 'red';
    diagDiv.textContent = diagStr;
    rightPanel.appendChild(diagDiv);
    
    window.chatHistory.push({ role: "System", content: diagStr });
  }
}

const textarea = document.querySelector('footer textarea');
const button = document.querySelector('footer button');

button.addEventListener('click', (e) => {
  e.preventDefault();
  const val = textarea.value.trim();
  if (val) {
    textarea.value = '';
    runAgent(val);
  }
});

textarea.addEventListener('keydown', (e) => {
  if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
    e.preventDefault();
    const val = textarea.value.trim();
    if (val) {
      textarea.value = '';
      runAgent(val);
    }
  }
});
</script>