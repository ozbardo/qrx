<style>
  .chat-container {
    display: flex;
    flex-direction: column;
    height: 100vh;
    font-family: sans-serif;
    box-sizing: border-box;
  }
  .chat-header {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
    padding: 15px;
    background-color: #f4f4f5;
    border-bottom: 1px solid #e4e4e7;
    align-items: center;
  }
  .header-item {
    display: flex;
    flex-direction: column;
    gap: 5px;
    font-size: 14px;
  }
  .chat-messages {
    flex: 1;
    overflow-y: auto;
    background-color: #ffffff;
    padding: 20px;
  }
  .chat-footer {
    display: flex;
    gap: 10px;
    padding: 15px;
    background-color: #f4f4f5;
    border-top: 1px solid #e4e4e7;
    align-items: flex-end;
  }
  .chat-textarea {
    flex: 1;
    resize: vertical;
    min-height: 44px;
    padding: 10px;
    border: 1px solid #e4e4e7;
    border-radius: 4px;
    font-family: inherit;
  }
  .chat-submit {
    padding: 0 20px;
    height: 44px;
    background-color: #09090b;
    color: #ffffff;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-weight: bold;
  }
</style>

<div class="chat-container">
  <header class="chat-header">
    <div class="header-item">
      <label for="model-details">Model Details</label>
      <input type="text" id="model-details" name="model-details">
    </div>
    <div class="header-item">
      <label for="model-name">Model Name</label>
      <input type="text" id="model-name" name="model-name">
    </div>
    <div class="header-item">
      <label for="model-host">Model Host</label>
      <input type="text" id="model-host" name="model-host">
    </div>
    <div class="header-item">
      <label for="api-key">API Key</label>
      <input type="password" id="api-key" name="api-key">
    </div>
  </header>

  <main class="chat-messages"></main>

  <footer class="chat-footer">
    <textarea class="chat-textarea"></textarea>
    <button type="submit" class="chat-submit">Submit</button>
  </footer>
</div><script>
  document.getElementById('model-name').value = localStorage.getItem('m') || '';
  document.getElementById('model-host').value = localStorage.getItem('h') || '';
  document.getElementById('api-key').value = localStorage.getItem('k') || '';
</script><script>
window.chatPlugins = {
  logger: {
    callback: function (currentPrompt, fullChat) {
      const transformedText = fullChat + (fullChat ? "\n" : "") + "User: " + currentPrompt;
      console.log("Transformed Context Sent to AI:\n", transformedText);
      return transformedText;
    }
  }
};

let chatHistoryString = "";

async function submitChat() {
  const hostInput = document.getElementById('model-host').value.trim();
  const nameInput = document.getElementById('model-name').value.trim();
  const keyInput = document.getElementById('api-key').value.trim();
  const textarea = document.querySelector('.chat-textarea');
  const messagesContainer = document.querySelector('.chat-messages');

  const userText = textarea.value.trim();
  if (!userText) return;

  textarea.value = '';

  let transformedPrompt = chatHistoryString;
  for (const pluginName in window.chatPlugins) {
    if (typeof window.chatPlugins[pluginName]?.callback === 'function') {
      transformedPrompt = window.chatPlugins[pluginName].callback(userText, transformedPrompt);
    }
  }

  chatHistoryString = transformedPrompt;

  const userDiv = document.createElement('div');
  userDiv.style.padding = '10px';
  userDiv.style.marginBottom = '10px';
  userDiv.style.backgroundColor = '#f4f4f5';
  userDiv.style.borderRadius = '6px';
  userDiv.style.whiteSpace = 'pre-wrap';
  userDiv.textContent = userText;
  messagesContainer.appendChild(userDiv);

  const aiDiv = document.createElement('div');
  aiDiv.style.padding = '10px';
  aiDiv.style.marginBottom = '10px';
  aiDiv.style.backgroundColor = '#fafafa';
  aiDiv.style.border = '1px solid #e4e4e7';
  aiDiv.style.borderRadius = '6px';
  aiDiv.style.whiteSpace = 'pre-wrap';
  aiDiv.textContent = '...';
  messagesContainer.appendChild(aiDiv);

  const isGoogle = hostInput.toLowerCase().includes('google');
  
  let url = hostInput;
  let headers = { 'Content-Type': 'application/json' };
  let body = {};

  if (isGoogle) {
    const baseHost = hostInput.replace(/\/$/, "");
    url = `${baseHost}/${nameInput}:streamGenerateContent?key=${keyInput}&alt=sse`;
    body = {
      contents: [{ role: "user", parts: [{ text: chatHistoryString }] }]
    };
  } else {
    headers['Authorization'] = `Bearer ${keyInput}`;
    body = {
      model: nameInput,
      stream: true,
      messages: [{ role: "user", content: chatHistoryString }]
    };
  }

  try {
    const response = await fetch(url, {
      method: 'POST',
      headers: headers,
      body: JSON.stringify(body)
    });

    if (!response.ok) {
      throw new Error(`Error: ${response.status}`);
    }

    const reader = response.body.getReader();
    const decoder = new TextDecoder('utf-8');
    let aiFullResponse = "";
    aiDiv.textContent = "";

    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      
      const chunk = decoder.decode(value, { stream: true });
      const lines = chunk.split('\n');

      for (const line of lines) {
        if (line.startsWith('data:')) {
          const dataStr = line.slice(5).trim();
          if (dataStr === '[DONE]' || !dataStr) continue;

          try {
            const data = JSON.parse(dataStr);
            let textPiece = "";
            if (isGoogle) {
              textPiece = data.candidates?.[0]?.content?.parts?.[0]?.text || "";
            } else {
              textPiece = data.choices?.[0]?.delta?.content || "";
            }
            aiFullResponse += textPiece;
            aiDiv.textContent = aiFullResponse;
          } catch (e) {
            
          }
        }
      }
    }
    chatHistoryString += "\nAI: " + aiFullResponse;
  } catch (err) {
    aiDiv.textContent = `[Request failed: ${err.message}]`;
  }
}

document.querySelector('.chat-submit').addEventListener('click', submitChat);

document.querySelector('.chat-textarea').addEventListener('keydown', function(e) {
  if (e.ctrlKey && e.key === 'Enter') {
    e.preventDefault();
    submitChat();
  }
});
</script><script>
(function() {
    window.chatPlugins.linkContextFetcher = {
        callback: function(currentPrompt, fullChat) {
            let transformedChat = fullChat;
            const matches = [...currentPrompt.matchAll(/\[\[([^\]]+)\]\]/g)];
            if (matches.length === 0) return fullChat;

            const promises = matches.map(match => {
                const originalTag = match[0];
                const inner = match[1];
                let name = window.DB;
                let link = inner;
                
                if (inner.includes('#')) {
                    const parts = inner.split('#', 2);
                    if (parts[0]) name = parts[0];
                    link = parts[1];
                }

                return new Promise(resolve => {
                    try {
                        read(link, name).then(context => {
                            console.log(`Link: ${name}#${link}`, context);
                            const wrappedContext = `<context file="${name}#${link}">\n${context}\n</context>`;
                            transformedChat = transformedChat.split(originalTag).join(wrappedContext);
                            resolve();
                        }).catch(e => {
                            resolve();
                        });
                    } catch (e) {
                        resolve();
                    }
                });
            });

            return Promise.all(promises).then(() => transformedChat);
        }
    };

    const origFetch = window.fetch;
    window.fetch = async function(url, options) {
        if (typeof chatHistoryString !== 'undefined' && chatHistoryString instanceof Promise) {
            try {
                const resolvedChat = await chatHistoryString;
                chatHistoryString = resolvedChat;
                
                if (options && options.body) {
                    const bodyObj = JSON.parse(options.body);
                    if (bodyObj.contents && bodyObj.contents[0]?.parts?.[0]) {
                        bodyObj.contents[0].parts[0].text = resolvedChat;
                    } else if (bodyObj.messages && bodyObj.messages[0]) {
                        bodyObj.messages[0].content = resolvedChat;
                    }
                    options.body = JSON.stringify(bodyObj);
                }
            } catch (e) {
                // Silently bypass block stringification failures
            }
        }
        return origFetch.call(this, url, options);
    };
})();
</script>